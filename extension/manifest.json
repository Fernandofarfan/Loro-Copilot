{
  "manifest_version": 3,
  "name": "Loro Copilot - Invisible Audio",
  "version": "1.0",
  "permissions": [
    "tabCapture",
    "activeTab",
    "offscreen",
    "tabs",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://*.deepgram.com/*"
  ],
  "action": {
    "default_title": "Capturar pestaña para Loro Copilot"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://localhost:3000/*"],
      "js": ["content.js"]
    }
  ]
}
